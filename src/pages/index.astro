  <script>
    const cards = document.querySelectorAll('.svc-card');

    cards.forEach((card, i) => {
      card.style.opacity = '0';
      card.style.transform = 'translateY(28px) scale(0.97)';

      const obs = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              card.style.transition = 'opacity 0.5s ease, transform 0.5s cubic-bezier(0.34,1.56,0.64,1)';
              card.style.opacity = '1';
              card.style.transform = 'translateY(0) scale(1)';
              setTimeout(() => {
                card.style.transition = '';
                card.style.opacity = '';
                card.style.transform = '';
              }, 650);
            }, i * 90);
            obs.unobserve(card);
          }
        });
      }, { threshold: 0.1 });

      obs.observe(card);
    });

    const heroSection = document.querySelector('.hero');
    const floatCards  = document.querySelectorAll('.hcard');
    const mascot      = document.querySelector('.tooth-mascot');

    if (heroSection) {
      heroSection.addEventListener('mousemove', e => {
        const { left, top, width, height } = heroSection.getBoundingClientRect();
        const mx = (e.clientX - left) / width  - 0.5;
        const my = (e.clientY - top)  / height - 0.5;

        floatCards.forEach((card, i) => {
          const depth = (i + 1) * 5;
          card.style.transform = `translate(${mx * depth}px, ${my * depth}px)`;
        });
        if (mascot) {
          mascot.style.transform = `translate(${mx * 8}px, ${my * 6}px) rotate(${mx * 2}deg)`;
        }
      });

      heroSection.addEventListener('mouseleave', () => {
        floatCards.forEach(c => c.style.transform = '');
        if (mascot) mascot.style.transform = '';
      });
    }
  </script>
