---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const hero = await reader.singletons.hero.read();

if (!hero) throw new Error('Hero content not found. Ensure src/content/hero.yaml exists.');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SmileBright — Friendly Dental Care</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,800&display=swap" rel="stylesheet" />

  <style>
    /* ─── Reset ────────────────────────────────────────────────────── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--ff);
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Tokens ────────────────────────────────────────────────────── */
    :root {
      --bg:         #fdfaf4;
      --bg-2:       #fff8ee;
      --white:      #ffffff;

      --sky:        #0ea5e9;
      --sky-mid:    #38bdf8;
      --sky-light:  #bae6fd;
      --sky-pale:   #e0f2fe;

      --peach:      #f97316;
      --peach-light:#fed7aa;
      --peach-pale: #fff7ed;

      --yellow:     #f59e0b;
      --yellow-pale:#fef3c7;

      --mint:       #10b981;
      --mint-pale:  #d1fae5;

      --rose:       #f43f5e;
      --rose-pale:  #ffe4e6;

      --violet:     #8b5cf6;
      --violet-pale:#ede9fe;

      --text:       #1a2340;
      --text-2:     #4a5568;
      --muted:      #94a3b8;
      --border:     rgba(0,0,0,0.08);
      --border-sky: rgba(14,165,233,0.25);

      --sh-sm:  0 2px 14px rgba(0,0,0,0.06);
      --sh-md:  0 8px 32px  rgba(0,0,0,0.09);
      --sh-lg:  0 20px 56px rgba(0,0,0,0.11);
      --sh-sky: 0 8px 28px  rgba(14,165,233,0.22);
      --sh-peach: 0 8px 28px rgba(249,115,22,0.18);

      --ff: 'Nunito', system-ui, sans-serif;

      --ease:   cubic-bezier(0.4, 0, 0.2, 1);
      --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
      --t:      0.3s var(--ease);

      --r-sm:   10px;
      --r-md:   18px;
      --r-lg:   26px;
      --r-xl:   36px;
      --r-2xl:  48px;
      --r-full: 9999px;
    }

    /* ─── Nav ───────────────────────────────────────────────────────── */
    nav {
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 100;
      height: 74px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 max(32px, 5.5vw);
      background: rgba(253,250,244,0.92);
      backdrop-filter: blur(18px) saturate(1.6);
      border-bottom: 2px solid var(--border);
      box-shadow: 0 2px 20px rgba(0,0,0,0.04);
    }

    .nav-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none;
    }
    .nav-mark {
      width: 40px; height: 40px;
      background: linear-gradient(135deg, var(--sky), var(--sky-mid));
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      box-shadow: var(--sh-sky);
      position: relative;
      overflow: hidden;
    }
    .nav-mark::after {
      content: '✦';
      font-size: 18px; color: white;
      display: flex; align-items: center; justify-content: center;
    }
    .nav-name {
      font-size: 1.3rem; font-weight: 900;
      color: var(--text);
      letter-spacing: -0.02em;
    }
    .nav-name span { color: var(--sky); }

    .nav-links {
      display: flex; gap: 34px; list-style: none;
    }
    .nav-links a {
      text-decoration: none;
      font-size: 0.9rem; font-weight: 700;
      color: var(--text-2);
      letter-spacing: 0.01em;
      transition: color var(--t);
    }
    .nav-links a:hover { color: var(--sky); }

    .nav-btns { display: flex; gap: 10px; align-items: center; }

    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--ff); font-weight: 800;
      border: none; cursor: pointer; border-radius: var(--r-full);
      transition: all 0.25s var(--spring);
      letter-spacing: -0.01em;
    }
    .btn:active { transform: scale(0.96) !important; }
    .btn-sm { padding: 9px 20px; font-size: 0.85rem; }
    .btn-md { padding: 14px 28px; font-size: 0.92rem; }
    .btn-lg { padding: 17px 36px; font-size: 1rem; }

    .btn-outline {
      background: transparent;
      border: 2px solid var(--border);
      color: var(--text);
    }
    .btn-outline:hover {
      border-color: var(--sky-light);
      color: var(--sky);
      background: var(--sky-pale);
      transform: translateY(-1px);
    }
    .btn-sky {
      background: var(--sky);
      color: white;
      box-shadow: var(--sh-sky);
    }
    .btn-sky:hover {
      background: var(--sky-mid);
      transform: translateY(-2px) scale(1.02);
      box-shadow: 0 12px 32px rgba(14,165,233,0.32);
    }
    .btn-peach {
      background: var(--peach);
      color: white;
      box-shadow: var(--sh-peach);
    }
    .btn-peach:hover {
      background: #fb923c;
      transform: translateY(-2px) scale(1.02);
    }

    /* ─── Hero ──────────────────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      padding-top: 74px;
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      align-items: center;
      padding-inline: max(44px, 7vw) max(44px, 5vw);
      position: relative;
      overflow: hidden;
      background: var(--bg);
    }

    /* Dot grid background */
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(circle, rgba(14,165,233,0.1) 1.5px, transparent 1.5px);
      background-size: 30px 30px;
      mask-image: radial-gradient(ellipse 80% 90% at 50% 50%, black 30%, transparent 100%);
      pointer-events: none;
    }

    /* Large soft peach circle in top-right corner */
    .hero-bg-blob {
      position: absolute;
      top: -180px; right: -180px;
      width: 560px; height: 560px;
      background: radial-gradient(circle, var(--peach-pale) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-bg-blob-2 {
      position: absolute;
      bottom: -120px; left: -100px;
      width: 400px; height: 400px;
      background: radial-gradient(circle, var(--sky-pale) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Scattered decorative stars */
    .deco {
      position: absolute;
      pointer-events: none;
      animation: deco-float 4s ease-in-out infinite;
    }
    .deco-star {
      font-size: var(--size, 16px);
      color: var(--color, var(--yellow));
      opacity: 0.7;
      display: block;
      animation: deco-float var(--dur, 4s) ease-in-out infinite var(--delay, 0s),
                 deco-spin 6s linear infinite var(--delay, 0s);
    }
    .deco-plus {
      font-size: var(--size, 18px);
      color: var(--color, var(--sky-light));
      opacity: 0.6;
      font-weight: 900;
      display: block;
      animation: deco-float var(--dur, 5s) ease-in-out infinite var(--delay, 0s);
    }
    @keyframes deco-float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50%       { transform: translateY(-14px) rotate(8deg); }
    }
    @keyframes deco-spin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    /* ── Hero Left ─────────────────────────────────────────────────── */
    .hero-content {
      position: relative; z-index: 2;
      padding-right: 48px;
      padding-block: 80px;
    }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--peach-pale);
      border: 2px solid var(--peach-light);
      border-radius: var(--r-full);
      padding: 7px 18px;
      font-size: 0.8rem; font-weight: 800;
      color: var(--peach);
      letter-spacing: 0.04em; text-transform: uppercase;
      margin-bottom: 26px;
      animation: pop-in 0.5s var(--spring) both;
    }
    .badge-icon { font-size: 0.9rem; }

    .hero-title {
      font-size: clamp(3rem, 5.2vw, 5rem);
      font-weight: 900;
      line-height: 1.06;
      letter-spacing: -0.04em;
      margin-bottom: 24px;
      animation: pop-in 0.5s var(--spring) 0.07s both;
      white-space: pre-line;
    }

    .hero-body {
      font-size: 1.08rem; line-height: 1.8;
      color: var(--text-2); font-weight: 500;
      max-width: 460px;
      margin-bottom: 40px;
      animation: pop-in 0.5s var(--spring) 0.14s both;
    }

    .hero-actions {
      display: flex; align-items: center; gap: 14px;
      margin-bottom: 56px;
      animation: pop-in 0.5s var(--spring) 0.21s both;
    }

    .hero-stats {
      display: flex; align-items: center; gap: 0;
      animation: pop-in 0.5s var(--spring) 0.28s both;
    }
    .stat-item {
      display: flex; flex-direction: column; gap: 4px;
      padding-inline: 24px;
    }
    .stat-item:first-child { padding-left: 0; }
    .stat-val {
      font-size: 2rem; font-weight: 900;
      letter-spacing: -0.04em; line-height: 1;
      color: var(--text);
    }
    .stat-label {
      font-size: 0.78rem; font-weight: 700;
      color: var(--muted);
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .stat-sep {
      width: 2px; height: 40px;
      background: var(--border);
      border-radius: 2px; flex-shrink: 0;
    }

    /* ── Hero Right ────────────────────────────────────────────────── */
    .hero-visual-wrap {
      position: relative; z-index: 2;
      display: flex; align-items: center; justify-content: center;
      height: calc(100vh - 74px);
      min-height: 580px;
      animation: pop-in 0.6s var(--spring) 0.1s both;
    }

    .hero-visual {
      position: relative;
      width: min(480px, 90%);
      aspect-ratio: 1;
      display: flex; align-items: center; justify-content: center;
    }

    /* The big pastel blob circle */
    .hero-blob {
      position: absolute; inset: 0;
      border-radius: 60% 40% 55% 45% / 50% 55% 45% 50%;
      background: linear-gradient(145deg, #e0f2fe 0%, #bae6fd 60%, #e0f2fe 100%);
      animation: blob-morph 8s ease-in-out infinite;
    }
    @keyframes blob-morph {
      0%,100% { border-radius: 60% 40% 55% 45% / 50% 55% 45% 50%; }
      33%     { border-radius: 45% 55% 40% 60% / 55% 45% 55% 45%; }
      66%     { border-radius: 55% 45% 60% 40% / 45% 60% 40% 55%; }
    }

    /* Ring around blob */
    .hero-ring {
      position: absolute;
      inset: -12px;
      border-radius: 60% 40% 55% 45% / 50% 55% 45% 50%;
      border: 2.5px dashed rgba(14,165,233,0.2);
      animation: blob-morph 8s ease-in-out infinite reverse, ring-spin 25s linear infinite;
    }
    @keyframes ring-spin {
      to { transform: rotate(360deg); }
    }

    /* Tooth SVG mascot */
    .tooth-mascot {
      position: relative; z-index: 3;
      width: 54%;
      filter: drop-shadow(0 12px 28px rgba(14,165,233,0.18));
      animation: mascot-float 3.5s ease-in-out infinite;
    }
    @keyframes mascot-float {
      0%,100% { transform: translateY(0) rotate(-1deg); }
      50%     { transform: translateY(-12px) rotate(1deg); }
    }

    /* Floating sparkle stars around the blob */
    .hero-sparkle {
      position: absolute;
      pointer-events: none;
    }
    .hero-sparkle svg { animation: sparkle-anim 2s ease-in-out infinite; }
    @keyframes sparkle-anim {
      0%,100% { transform: scale(1) rotate(0deg); opacity: 0.85; }
      50%      { transform: scale(1.3) rotate(20deg); opacity: 1; }
    }

    /* Floating cards */
    .hcard {
      position: absolute; z-index: 4;
      background: var(--white);
      border-radius: var(--r-xl);
      padding: 14px 18px;
      box-shadow: var(--sh-md);
      border: 2px solid rgba(0,0,0,0.05);
    }

    .hcard-rating {
      top: 10%; left: -6%;
      display: flex; align-items: center; gap: 12px;
      animation: card-float-a 4s ease-in-out infinite;
    }
    .rating-emoji {
      font-size: 2rem;
      line-height: 1;
    }
    .rating-score {
      font-size: 1.5rem; font-weight: 900;
      color: var(--text); letter-spacing: -0.04em; line-height: 1;
    }
    .rating-stars { color: var(--yellow); font-size: 0.72rem; letter-spacing: 1px; margin-top: 2px; }
    .rating-sub { font-size: 0.7rem; font-weight: 700; color: var(--muted); margin-top: 2px; }

    .hcard-patients {
      bottom: 22%; left: -10%;
      animation: card-float-b 5s ease-in-out infinite;
    }
    .patients-label {
      font-size: 0.68rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--sky); margin-bottom: 4px;
    }
    .patients-num {
      font-size: 1.9rem; font-weight: 900;
      color: var(--text); letter-spacing: -0.04em; line-height: 1;
    }
    .patients-trend {
      display: flex; align-items: center; gap: 5px;
      font-size: 0.72rem; font-weight: 700;
      color: var(--mint); margin-top: 5px;
    }
    .trend-pill {
      background: var(--mint-pale);
      padding: 2px 8px; border-radius: var(--r-full);
    }

    .hcard-appt {
      top: 32%; right: -8%;
      min-width: 168px;
      animation: card-float-c 4.5s ease-in-out infinite;
      border-top: 4px solid var(--peach);
    }
    .appt-row {
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 8px;
    }
    .appt-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--mint);
      box-shadow: 0 0 8px rgba(16,185,129,0.5);
      flex-shrink: 0;
    }
    .appt-badge-label {
      font-size: 0.68rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--text);
    }
    .appt-time {
      font-size: 1.15rem; font-weight: 900;
      color: var(--text); letter-spacing: -0.02em;
      margin-bottom: 3px;
    }
    .appt-doc { font-size: 0.72rem; font-weight: 700; color: var(--text-2); }
    .appt-chip {
      display: inline-flex; align-items: center; gap: 5px;
      margin-top: 9px;
      background: var(--sky-pale);
      border-radius: var(--r-full);
      padding: 4px 12px;
      font-size: 0.68rem; font-weight: 800;
      color: var(--sky);
    }

    @keyframes card-float-a { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
    @keyframes card-float-b { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
    @keyframes card-float-c { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-15px)} }

    @keyframes pop-in {
      from { opacity: 0; transform: translateY(18px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ─── Wave Divider ──────────────────────────────────────────────── */
    .wave-divider {
      display: block;
      margin-top: -2px;
      background: var(--bg);
    }
    .wave-divider svg { display: block; width: 100%; }

    /* ─── Services ──────────────────────────────────────────────────── */
    .services {
      padding: 20px max(44px, 7vw) 110px;
      background: var(--white);
      position: relative;
    }

    /* Accent blobs in services bg */
    .svc-blob-1 {
      position: absolute; top: -80px; right: -80px;
      width: 400px; height: 400px;
      background: radial-gradient(circle, var(--sky-pale) 0%, transparent 65%);
      pointer-events: none;
    }
    .svc-blob-2 {
      position: absolute; bottom: -60px; left: -60px;
      width: 350px; height: 350px;
      background: radial-gradient(circle, var(--yellow-pale) 0%, transparent 65%);
      pointer-events: none;
    }

    .svc-header {
      display: flex; align-items: flex-end; justify-content: space-between;
      margin-bottom: 60px;
      position: relative; z-index: 1;
      padding-top: 80px;
    }

    .eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 0.75rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--peach);
      margin-bottom: 14px;
    }
    .eyebrow-icon { font-size: 1rem; }

    .svc-title {
      font-size: clamp(2.2rem, 4vw, 3.2rem);
      font-weight: 900; letter-spacing: -0.04em;
      line-height: 1.1; color: var(--text);
    }
    .svc-title em { font-style: italic; color: var(--sky); }

    .svc-link {
      display: inline-flex; align-items: center; gap: 8px;
      text-decoration: none;
      font-size: 0.9rem; font-weight: 800;
      color: var(--sky);
      border-bottom: 2px solid var(--sky-light);
      padding-bottom: 3px;
      transition: all var(--t);
      flex-shrink: 0; margin-bottom: 10px;
    }
    .svc-link:hover { gap: 13px; border-color: var(--sky); }

    /* ── Service Grid ──────────────────────────────────────────────── */
    .svc-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      position: relative; z-index: 1;
    }

    .svc-card {
      background: var(--white);
      border: 2px solid var(--border);
      border-radius: var(--r-xl);
      padding: 32px 28px;
      cursor: pointer;
      position: relative; overflow: hidden;
      transition: transform 0.3s var(--spring), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
    }
    .svc-card:hover {
      transform: translateY(-6px) rotate(var(--rot, 0.6deg)) scale(1.02);
      box-shadow: var(--sh-lg);
      border-color: var(--c-border, var(--sky-light));
    }
    /* Alternating rotate direction */
    .svc-card:nth-child(even) { --rot: -0.6deg; }

    /* Colorful top accent strip on hover */
    .svc-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; height: 4px;
      background: var(--c-accent, var(--sky));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.35s var(--spring);
      border-radius: 0 0 4px 4px;
    }
    .svc-card:hover::before { transform: scaleX(1); }

    /* Icon bubble */
    .svc-icon {
      width: 60px; height: 60px;
      border-radius: 20px;
      background: var(--c-pale, var(--sky-pale));
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 22px;
      transition: transform 0.3s var(--spring);
    }
    .svc-card:hover .svc-icon { transform: scale(1.1) rotate(-5deg); }

    .svc-row {
      display: flex; align-items: flex-start; justify-content: space-between;
      margin-bottom: 11px;
    }
    .svc-name {
      font-size: 1.15rem; font-weight: 900;
      color: var(--text); letter-spacing: -0.02em;
      line-height: 1.2;
    }
    .svc-arrow {
      color: var(--muted); flex-shrink: 0; margin-top: 2px;
      transition: transform 0.3s var(--spring), color 0.3s var(--ease);
    }
    .svc-card:hover .svc-arrow {
      transform: translate(4px, -4px);
      color: var(--c-accent, var(--sky));
    }
    .svc-desc {
      font-size: 0.87rem; line-height: 1.74;
      color: var(--text-2); font-weight: 500;
      margin-bottom: 20px;
    }
    .svc-pill {
      display: inline-block;
      font-size: 0.7rem; font-weight: 800;
      color: var(--c-accent, var(--sky));
      background: var(--c-pale, var(--sky-pale));
      padding: 4px 13px; border-radius: var(--r-full);
      text-transform: uppercase; letter-spacing: 0.07em;
    }

    /* Per-card colors */
    .c-sky    { --c-accent: var(--sky);    --c-pale: var(--sky-pale);    --c-border: var(--sky-light); }
    .c-violet { --c-accent: var(--violet); --c-pale: var(--violet-pale); --c-border: #c4b5fd; }
    .c-mint   { --c-accent: var(--mint);   --c-pale: var(--mint-pale);   --c-border: #6ee7b7; }
    .c-peach  { --c-accent: var(--peach);  --c-pale: var(--peach-pale);  --c-border: var(--peach-light); }
    .c-yellow { --c-accent: var(--yellow); --c-pale: var(--yellow-pale); --c-border: #fde68a; }
    .c-rose   { --c-accent: var(--rose);   --c-pale: var(--rose-pale);   --c-border: #fda4af; }

    /* ── CTA Banner ────────────────────────────────────────────────── */
    .svc-cta {
      margin-top: 60px;
      border-radius: var(--r-2xl);
      padding: 52px 56px;
      display: flex; align-items: center; justify-content: space-between;
      position: relative; overflow: hidden; z-index: 1;
      background: var(--bg);
      border: 2px dashed var(--sky-light);
    }
    .svc-cta::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, var(--sky-pale) 0%, var(--peach-pale) 100%);
      opacity: 0.7;
    }
    .cta-content { position: relative; z-index: 1; }
    .cta-emoji { font-size: 2.4rem; display: block; margin-bottom: 10px; }
    .cta-title {
      font-size: clamp(1.4rem, 2.5vw, 1.8rem);
      font-weight: 900; letter-spacing: -0.03em;
      color: var(--text); line-height: 1.25;
    }
